# Backend
APP_NAME=Lana Project API
APP_ENV=dev
DEBUG=true
DATABASE_URL=postgresql+psycopg://lana:lana@localhost:5432/lana_dev
BINANCE_FAPI_BASE_URL=https://fapi.binance.com
BINANCE_HTTP_TIMEOUT_SECONDS=20
COINGECKO_API_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_HTTP_TIMEOUT_SECONDS=20
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC
SCHEDULER_INTERVAL_MINUTES=15
SCHEDULER_RUN_ON_STARTUP=false
SCHEDULER_STEP_RETRY_COUNT=2
SCHEDULER_STEP_RETRY_DELAY_SECONDS=1.5
GAP_CHECK_ENABLED=true
GAP_CHECK_HOURS=24
GAP_CHECK_MAX_SYMBOLS=300
GAP_CHECK_HOUR=0
GAP_CHECK_MINUTE=20
AUTO_POOL_BINANCE_MIN_QUOTE_VOLUME=10000000
AUTO_POOL_CANDIDATE_MAX_FROM_SOURCES=100
AUTO_POOL_COOLDOWN_HOURS=24
AUTO_INIT_NEW_SYMBOLS=true
AUTO_INIT_DAYS=30
AUTO_INIT_MAX_SYMBOLS_PER_CYCLE=5
CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Frontend
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000
